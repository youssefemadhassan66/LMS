CONNECTION_STRING=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/lms?retryWrites=true&w=majority
PORT=3000
NODE_ENV=production

ALLOWED_ORIGINS=https://your-frontend-domain.com
CLIENT_URL=https://your-frontend-domain.com

SALT_ROUNDS=12
JWT_TOKEN_SECRET=replace-with-at-least-32-random-characters
JWT_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=replace-with-another-32-random-characters
JWT_REFRESH_EXPIRES_IN=9

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=900000
REQUEST_TIMEOUT=30000
